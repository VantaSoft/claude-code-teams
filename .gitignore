# Build artifacts
node_modules/
dist/

# Claude Code local state (not shared across installs)
.claude/scheduled_tasks.json
.claude/scheduled_tasks.lock

# Agent memory (personal to each deployment)
agents/*/memory/*
!agents/*/memory/MEMORY.md

# Plugin-installed skills/plugins/cache (bloats repo; reinstalled per-deployment)
agents/*/.claude/plugins/
agents/*/.claude/cache/

# Per-install config generated from a committed .example (absolute paths / secrets).
# The .example templates are tracked; the substituted output is not.
agents/*/.claude/settings.local.json
agents/*/.mcp.json

# reclaude skills scaffolded at setup (recall is regenerable; llm-wiki has a
# per-install vault path substituted in). Source of truth lives in top-level skills/.
agents/*/.claude/skills/recall/
agents/*/.claude/skills/llm-wiki/

# Per-install settings that might contain secrets
.claude/channels/
*.env

# OS junk
.DS_Store
